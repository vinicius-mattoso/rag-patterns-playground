LLM_PROVIDER=openai
LLM_MODEL=gpt-4o-mini
OLLAMA_BASE_URL=http://localhost:11434

DATA_PATH=data/raw
ONTOLOGY_PATH=ontology.yaml
GRAPH_HTML_PATH=artifacts/knowledge_graph.html

NEO4J_URI=bolt://localhost:7687
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=change-me
NEO4J_DATABASE=neo4j
NEO4J_TIMEOUT_SECONDS=30
NEO4J_ENHANCED_SCHEMA=false

REBUILD_GRAPH=false
INCLUDE_SOURCE_DOCUMENTS=true
BASE_ENTITY_LABEL=true
STRICT_MODE=true

CHUNK_SIZE=900
CHUNK_OVERLAP=180
QUERY_TOP_K=8
CONTEXT_LIMIT=6
VISUALIZATION_LIMIT=180
INLINE_TEXTS=
